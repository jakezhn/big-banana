{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bitpunk.local/schemas/execution-intent.schema.json",
  "title": "Execution Intent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action",
    "plan_version_id",
    "trading_account_id",
    "symbol",
    "side",
    "order_type",
    "time_in_force",
    "qty",
    "price",
    "stop_price",
    "reduce_only",
    "client_order_id",
    "idempotency_key"
  ],
  "properties": {
    "action": {
      "enum": ["open", "amend", "cancel", "reduce", "close"]
    },
    "plan_version_id": {
      "type": "string"
    },
    "trading_account_id": {
      "type": "string"
    },
    "symbol": {
      "type": "string"
    },
    "side": {
      "enum": ["buy", "sell"]
    },
    "order_type": {
      "enum": ["limit", "market", "conditional"]
    },
    "time_in_force": {
      "enum": ["GTC", "IOC", "FOK", "PostOnly"]
    },
    "qty": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "price": {
      "type": ["number", "null"]
    },
    "stop_price": {
      "type": ["number", "null"]
    },
    "reduce_only": {
      "type": "boolean"
    },
    "client_order_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 36
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "action": {
            "enum": ["reduce", "close"]
          }
        }
      },
      "then": {
        "properties": {
          "reduce_only": {
            "const": true
          }
        }
      }
    }
  ]
}
