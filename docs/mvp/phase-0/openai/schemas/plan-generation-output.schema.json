{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plan Generation Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["trade_plan", "risk_plan"],
  "properties": {
    "trade_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "direction",
        "confidence",
        "thesis",
        "entry_plan",
        "take_profit_plan",
        "invalidation_plan",
        "management_rules",
        "expiry_rules"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["drafted", "active_waiting_entry"]
        },
        "direction": {
          "type": "string",
          "enum": ["long", "short"]
        },
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "thesis": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "summary",
            "regime_read",
            "structure_read",
            "context_read",
            "invalid_if"
          ],
          "properties": {
            "summary": { "type": "string", "minLength": 1 },
            "regime_read": { "type": "string", "minLength": 1 },
            "structure_read": { "type": "string", "minLength": 1 },
            "context_read": { "type": "string", "minLength": 1 },
            "invalid_if": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "entry_plan": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "entry_rationale", "entry_variants"],
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["market_now", "limit_on_pullback", "breakout_retest"]
            },
            "entry_rationale": {
              "type": "string",
              "minLength": 1
            },
            "entry_variants": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["variant_id", "type", "enabled", "condition", "zone"],
                "properties": {
                  "variant_id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "type": {
                    "type": "string",
                    "enum": ["market_now", "limit_zone", "breakout_retest"]
                  },
                  "enabled": {
                    "type": "boolean"
                  },
                  "condition": {
                    "type": "string",
                    "minLength": 1
                  },
                  "zone": {
                    "type": ["object", "null"],
                    "additionalProperties": false,
                    "required": ["low", "high", "basis"],
                    "properties": {
                      "low": { "type": "number" },
                      "high": { "type": "number" },
                      "basis": {
                        "type": "array",
                        "items": { "type": "string", "minLength": 1 }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "take_profit_plan": {
          "type": "object",
          "additionalProperties": false,
          "required": ["targets", "notes"],
          "properties": {
            "targets": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["label", "price", "rationale"],
                "properties": {
                  "label": { "type": "string", "minLength": 1 },
                  "price": { "type": "number" },
                  "rationale": { "type": "string", "minLength": 1 }
                }
              }
            },
            "notes": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "invalidation_plan": {
          "type": "object",
          "additionalProperties": false,
          "required": ["hard_invalidation_rules", "stop_idea"],
          "properties": {
            "hard_invalidation_rules": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "stop_idea": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "management_rules": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "expiry_rules": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "risk_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_initial_risk_pct",
        "size_guidance",
        "invalid_if",
        "reduce_risk_if",
        "exposure_constraints",
        "notes"
      ],
      "properties": {
        "max_initial_risk_pct": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "size_guidance": {
          "type": "string",
          "minLength": 1
        },
        "invalid_if": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "reduce_risk_if": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "exposure_constraints": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "notes": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
