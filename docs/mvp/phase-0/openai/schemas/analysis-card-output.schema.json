{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Analysis Card Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary_line",
    "detailed_explanation",
    "suggested_bias",
    "confidence",
    "risks"
  ],
  "properties": {
    "summary_line": {
      "type": "string",
      "minLength": 1
    },
    "detailed_explanation": {
      "type": "string",
      "minLength": 1
    },
    "suggested_bias": {
      "type": "string",
      "enum": ["long", "short", "neutral", "wait"]
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
