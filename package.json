{
  "name": "big-banana",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "db:migrate:remote": "bash scripts/apply-remote-migrations.sh",
    "smoke:paper": "bash scripts/run-paper-smoke.sh",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "dev:api": "pnpm --filter @big-banana/api dev",
    "dev:hermes": "pnpm --filter @big-banana/hermes dev",
    "dev:web": "pnpm --filter @big-banana/web dev",
    "test:api": "pnpm --filter @big-banana/api test",
    "test:contracts": "pnpm --filter @big-banana/contracts test",
    "test:domain": "pnpm --filter @big-banana/domain test",
    "test:hermes": "pnpm --filter @big-banana/hermes test",
    "test:web": "pnpm --filter @big-banana/web test"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
